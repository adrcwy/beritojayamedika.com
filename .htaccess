<IfModule mod_rewrite.c>
RewriteEngine On

# Force HTTPS sebelum request di-rewrite internal ke folder public.
# Ini mencegah browser dilempar ke /public saat HTTPS redirect terjadi.
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Bersihkan URL lama/keliru yang sudah mengarah ke /public.
# Laravel tetap memakai folder public secara internal, tapi URL user harus tetap di root domain.
RewriteCond %{THE_REQUEST} \s/+public/?([^\s?]*) [NC]
RewriteRule ^public/?(.*)$ /$1 [R=301,L,NE]

# Root domain langsung masuk ke front controller Laravel.
# Ini menghindari server mengekspos folder /public sebagai redirect eksternal.
RewriteRule ^$ public/index.php [L]

# Blokir akses ke file sensitif
RewriteRule ^\.env$ - [F,L]
RewriteRule ^\.env\..*$ - [F,L]
RewriteRule composer\.(json|lock)$ - [F,L]
RewriteRule package(-lock)?\.json$ - [F,L]
RewriteRule ^artisan$ - [F,L]
RewriteRule ^phpunit\.xml$ - [F,L]
RewriteRule ^storage/app/public/ - [L]
RewriteCond %{REQUEST_URI} !^/storage/app/public/
RewriteRule ^storage/ - [F,L]

RewriteCond %{REQUEST_URI} !^/public(/|$)
RewriteCond %{DOCUMENT_ROOT}/public/$1 -f [OR]
RewriteCond %{DOCUMENT_ROOT}/public/$1 -d
RewriteRule ^(.*)$ public/$1 [L]

RewriteCond %{REQUEST_URI} !^/public(/|$)
RewriteRule ^(.*)$ public/index.php [L]
</IfModule>

# Block access to sensitive file types
<FilesMatch "\.(env|log|sql|bak|old|orig|save|swp|swo|tmp|dist|fla|psd|ini|sh|bat|conf|yaml|yml|toml)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block specific sensitive files by name
<FilesMatch "^(\.env|composer\.json|composer\.lock|package\.json|package-lock\.json|phpunit\.xml|\.gitignore|README\.md|webpack\.mix\.js|vite\.config\.js|tailwind\.config\.js|postcss\.config\.js)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to hidden files (except .well-known for SSL)
<IfModule mod_rewrite.c>
    RewriteRule "(^|/)\.(?!well-known)" - [F]
</IfModule>

# Disable directory listing
Options -Indexes

# Prevent server info leaking
ServerSignature Off
